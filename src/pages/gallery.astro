---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Gallery from '../components/Gallery.astro';
import Footer from '../components/Footer.astro';
import siteData from '../data/site.json';
---

<Layout title="Gallery | MC the Barber" description="View the full photo gallery from MC the Barber at Señor Brims Barbershop in Allen, TX.">
  <Navbar />

  <main id="main-content">
    <Gallery fullPage={true} />

    <div class="gallery-page__instagram">
      <p class="gallery-page__instagram-text">Want to see more? Follow us on Instagram for the latest cuts and styles.</p>
      <a
        href={siteData.social.instagram}
        class="btn btn--primary"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Follow MC the Barber on Instagram (opens in new tab)"
      >
        ◉ &nbsp;Follow on Instagram
      </a>
    </div>
  </main>

  <Footer />
</Layout>

<style is:global>
  section[id] {
    scroll-margin-top: 80px;
  }

  .gallery-page__instagram {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-12) var(--space-4);
    text-align: center;
  }

  .gallery-page__instagram-text {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
